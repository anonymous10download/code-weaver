# Copy to .env and adjust. docker-compose substitutes ${VAR} from this file
# automatically (compose looks for `.env` next to docker-compose.yml).

# Runtime feature flag for the Nextcloud connector.
# "true"  → Nextcloud entry points are shown (default).
# "false" → Nextcloud button is hidden in the UI and any previously saved
#            Nextcloud source is ignored on load.
# Read at container start by docker/render-config.sh, which regenerates
# /usr/share/nginx/html/config.js — no image rebuild required to toggle.
NEXTCLOUD_ENABLED=true
